{
  "expo": {
    "name": "LifeLine",
    "slug": "lifeline_expo",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lifelineexpo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone.",
        "UIBackgroundModes": ["fetch", "remote-notification", "location"],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "LIFELINE needs your location to send weather alerts and SOS notifications even when the app is in the background.",
        "NSLocationAlwaysUsageDescription": "LIFELINE needs your location to monitor weather conditions and send emergency alerts.",
        "NSLocationWhenInUseUsageDescription": "LIFELINE needs your location to find the nearest evacuation center and send SOS alerts."
      }
    },
    "android": {
      "package": "com.ayaanjao.lifeline_expo",
      "versionCode": 5,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#B00020"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#B00020"
        }
      ],
      "expo-speech-recognition",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#B00020",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "LIFELINE Alert"
        }
      ],
      [
        "expo-background-fetch",
        {
          "stopOnTerminate": false,
          "startOnBoot": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "LIFELINE needs your location to send weather alerts and SOS notifications even when the app is in the background.",
          "locationAlwaysPermission": "LIFELINE needs your location to monitor weather conditions and send emergency alerts.",
          "locationWhenInUsePermission": "LIFELINE needs your location to find the nearest evacuation center and send SOS alerts.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a35b5dbd-7933-4073-b5e3-5e4d31ecf0df"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a35b5dbd-7933-4073-b5e3-5e4d31ecf0df"
    }
  }
}